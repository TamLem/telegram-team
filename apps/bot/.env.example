# Copy to .env.local at the project root.
# The config package loads .env.local automatically from the workspace root.
#
# Required variables:

BOT_TOKEN=
BOT_USERNAME=
BOT_UPDATE_MODE=webhook
BOT_WEBHOOK_SECRET=
API_BASE_URL=http://localhost:3001
MINIAPP_BASE_URL=http://localhost:3002
MINIAPP_CONTEXT_SECRET=
INTERNAL_API_KEY=

# Webhook mode (used when BOT_UPDATE_MODE=webhook):
# BOT_WEBHOOK_URL=
# BOT_PORT=3000

# Polling mode (used when BOT_UPDATE_MODE=polling):
# BOT_POLL_TIMEOUT_SECONDS=30
# BOT_MAX_UPDATE_FAILURES=10
# BOT_RETRY_DELAY_MS=5000
