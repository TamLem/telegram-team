# Local development — copy to .env.local and fill in values
# The config package loads .env.local automatically from the workspace root.

# --- Common ---
NODE_ENV=development

# --- API (apps/api) ---
API_PORT=3001
INTERNAL_API_KEY=
MINIAPP_CONTEXT_SECRET=
# DATABASE_URL defaults to ../../data/app.db. Set only to override.
# DATABASE_URL=

# --- Mini App (apps/miniapp) ---
MINIAPP_PORT=3002
API_BASE_URL=http://localhost:3001
BOT_TOKEN=
MINIAPP_CONTEXT_SECRET=
# MINIAPP_DEV_USER_ID=

# --- Bot (apps/bot) ---
BOT_TOKEN=
BOT_USERNAME=
BOT_UPDATE_MODE=polling
BOT_WEBHOOK_SECRET=
BOT_WEBHOOK_URL=
BOT_PORT=3000
INTERNAL_API_KEY=
API_BASE_URL=http://localhost:3001
MINIAPP_CONTEXT_SECRET=

# Polling mode settings (used when BOT_UPDATE_MODE=polling):
DROP_PENDING_UPDATES=false
BOT_ALLOWED_UPDATES=message,callback_query
BOT_POLL_TIMEOUT_SECONDS=30
BOT_MAX_UPDATE_FAILURES=10
BOT_RETRY_DELAY_MS=5000
BOT_HANDLER_TIMEOUT_MS=25000
BOT_GET_UPDATES_REQUEST_TIMEOUT_MS=35000

# The Cloudflare Tunnel URL is set automatically by the root dev script.
# If running manually, set it yourself:
MINIAPP_BASE_URL=http://localhost:3002
