# Local development — copy to .env.local and fill in values

# --- Common ---
NODE_ENV=development

# --- API (apps/api) ---
API_PORT=3001
# DATABASE_URL defaults to data/app.db in the workspace root. Set only to override.
# DATABASE_URL=

# --- Mini App (apps/miniapp) ---
MINIAPP_PORT=3102
API_BASE_URL=http://localhost:3001

# --- Bot (apps/bot) ---
BOT_TOKEN=
BOT_USERNAME=
BOT_UPDATE_MODE=polling
BOT_WEBHOOK_SECRET=
BOT_WEBHOOK_URL=
BOT_PORT=3100
DROP_PENDING_UPDATES=true

# The Cloudflare Tunnel URL is set automatically by the root dev script.
# If running manually, set it yourself:
MINIAPP_BASE_URL=

# Dev user for Mini App auth bypass (Telegram user ID)
MINIAPP_DEV_USER_ID=
