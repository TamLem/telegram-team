# Copy to .env.local and fill in values.
# The config package auto-loads .env.local from the workspace root.
#
# Development: pnpm dev (starts all 3 services + Cloudflare tunnel)
# Production:  Docker Compose via Coolify (see docs/deployment.md)

# --- Common ---
NODE_ENV=production

# --- Internal secrets (generate with: openssl rand -hex 32) ---
INTERNAL_API_KEY=
MINIAPP_CONTEXT_SECRET=

# --- API (apps/api) ---
API_PORT=3001
# DATABASE_URL defaults to ../../data/app.db — set only to override
# DATABASE_URL=

# --- Mini App (apps/miniapp) ---
MINIAPP_PORT=3002
API_BASE_URL=http://localhost:3001
BOT_TOKEN=
# MINIAPP_DEV_USER_ID=           # Dev only: bypass initData check for a specific Telegram user ID

# --- Bot (apps/bot) ---
BOT_TOKEN=
BOT_USERNAME=
BOT_UPDATE_MODE=webhook          # "webhook" for production, "polling" for development
BOT_WEBHOOK_SECRET=              # Shared with Telegram; verifies webhook origin
BOT_WEBHOOK_URL=                 # Public URL, e.g. https://taskpilot.example.com
BOT_PORT=3000
API_BASE_URL=http://localhost:3001
# API_BASE_URL=http://api:3001   # Docker Compose (service name)
MINIAPP_BASE_URL=                # Public Mini App URL, e.g. https://taskpilot.example.com

# Polling mode settings (only used when BOT_UPDATE_MODE=polling)
DROP_PENDING_UPDATES=false
BOT_ALLOWED_UPDATES=message,callback_query
BOT_POLL_TIMEOUT_SECONDS=30
BOT_MAX_UPDATE_FAILURES=10
BOT_RETRY_DELAY_MS=5000
BOT_HANDLER_TIMEOUT_MS=25000
BOT_GET_UPDATES_REQUEST_TIMEOUT_MS=35000

# --- Development only ---
# MINIAPP_BASE_URL=http://localhost:3002
# The Cloudflare Tunnel URL is set automatically by scripts/dev.ts
